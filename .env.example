# Template documenting the environment variables this app uses.
# NOTE: `.env` is tracked in git on purpose — Lovable generates it and the build
# reads VITE_* values from it; it contains only publishable (public) keys.
# Real secrets (service role, API keys) are provided by the hosting environment
# at runtime and must never appear in `.env` or any committed file.

# Supabase — client-side (bundled into the browser build; publishable/anon values only)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
VITE_SUPABASE_PROJECT_ID=your_project_id

# Supabase — server-side (SSR / server functions)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_PROJECT_ID=your_project_id

# Server-only secrets — NEVER expose to the client, NEVER commit.
# Provided by the hosting environment at runtime.
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
# LOVABLE_API_KEY=xxx
